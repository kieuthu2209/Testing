<div class="page-container">
  <div class="page-header">
    <a href="/staff/products" class="back-link">← Back to Staff Products</a>
    <h1 class="page-title">Order for Customer</h1>
    <p class="page-subtitle">Create an order assigned to a customer account.</p>
  </div>

  {{#if error}}
  <div class="alert alert-error">{{error}}</div>
  {{/if}}

  <form method="POST" action="/staff/orders" class="checkout-form staff-form">
    <section class="form-section">
      <h2 class="form-section-title">Customer</h2>
      <div class="form-group">
        <label class="form-label">Customer Account</label>
        <select class="form-input" name="customerId" required>
          <option value="">Choose customer</option>
          {{#each customers}}
          <option value="{{id}}" {{#if (eq id ../form.customerId)}}selected{{/if}}>{{name}} · {{email}}</option>
          {{/each}}
        </select>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Ship To Name</label>
          <input class="form-input" type="text" name="name" value="{{form.name}}" placeholder="Use customer name">
        </div>
        <div class="form-group">
          <label class="form-label">Shipping Address</label>
          <input class="form-input" type="text" name="address" value="{{form.address}}" placeholder="Use customer address">
        </div>
      </div>
    </section>

    <section class="form-section">
      <h2 class="form-section-title">Products</h2>
      <div class="staff-order-lines">
        {{#each products}}
        <div class="staff-order-line">
          <input type="hidden" name="productId" value="{{id}}">
          <div>
            <p class="staff-product-name">{{name}}</p>
            <p class="summary-detail">${{price}} · {{category}} · {{type}}</p>
          </div>
          <input class="qty-input staff-qty-input" type="number" name="qty" min="0" max="99" value="0" aria-label="Quantity for {{name}}">
        </div>
        {{/each}}
      </div>
    </section>

    <button type="submit" class="btn-primary btn-large">Create Order</button>
  </form>
</div>
